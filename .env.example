# Workshift landing — example env. Zkopiuj do .env.local i wypełnij.

# === Resend (newsletter, kontakt) ===
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...
RESEND_FROM_EMAIL=kontakt@workshift.pl
RESEND_NOTIFY_TO=kontakt@workshift.pl
RESEND_DOI_SECRET=...
RESEND_CONFIRM_URL=https://workshift.pl/#/potwierdz-email
RESEND_DOI_REDIRECT_URL=https://workshift.pl/#/dziekuje-za-zapis
RESEND_WEBHOOK_SECRET=whsec_...

# === Offer pages (private offers — /oferta/[slug]) ===
# Sekret HMAC: generuj `openssl rand -hex 32`
OFFER_JWT_SECRET=...
# Hasła per slug — pattern OFFER_PASSWORD_<SLUG_UPPER>
OFFER_PASSWORD_INFORMAX=...
